# 실제 사용 시 이 파일을 .env 로 복사한 뒤 키를 입력하세요.
# cp .env.example .env

ANTHROPIC_API_KEY=your-anthropic-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
AI_PROVIDER=gemini          # gemini 또는 anthropic
CRAWL_DELAY=2               # 사이트 간 대기 시간(초)
MAX_PAGES=3                 # 페이지당 최대 수집 페이지 수
SEARCH_DAYS=3              # 게시일이 최근 N일 이내인 공고만 통과 (0=제한없음)
LOG_LEVEL=INFO
